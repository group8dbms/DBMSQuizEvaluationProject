    {
      "name": "Exams",
      "item": [
        {
          "name": "List Exams",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/exams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "exams"
              ]
            }
          }
        },
        {
          "name": "Create Active Exam",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.environment.set('examId', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Active Exam\",\n  \"start_time\": \"{{examStartTime}}\",\n  \"end_time\": \"{{examEndTime}}\",\n  \"config_json\": {\n    \"duration_minutes\": 60,\n    \"tab_switch_limit\": 3\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/exams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "exams"
              ]
            },
            "description": "Set `examStartTime` to a recent past ISO timestamp and `examEndTime` to a future ISO timestamp in the environment before sending."
          }
        },
        {
          "name": "Add Question To Exam",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.environment.set('questionId', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What does DBMS stand for?\",\n  \"type\": \"short_answer\",\n  \"correct_answer\": \"Database Management System\",\n  \"marks\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/exams/{{examId}}/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "exams",
                "{{examId}}",
                "questions"
              ]
            }
          }
        }
      ]
    },
